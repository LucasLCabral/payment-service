# .env.example - Copie para .env e ajuste os valores

# Environment
ENVIRONMENT=development

# API Gateway Service
API_GATEWAY_PORT=8080
# Endereço gRPC do payment-service (cliente no gateway)
PAYMENT_GRPC_ADDR=localhost:9090

# Payment Service
PAYMENT_GRPC_PORT=9090
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5432
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=payment_pass
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_SSLMODE=disable

# Ledger Service
LEDGER_DB_HOST=localhost
LEDGER_DB_PORT=5433
LEDGER_DB_USER=ledger_user
LEDGER_DB_PASSWORD=ledger_pass
LEDGER_DB_NAME=ledger_db
LEDGER_DB_SSLMODE=disable

# RabbitMQ
RABBITMQ_URL=amqp://rabbit_user:rabbit_pass@localhost:5672/

# Redis
REDIS_URL=redis://localhost:6379

# Jaeger
JAEGER_ENDPOINT=http://localhost:4318
